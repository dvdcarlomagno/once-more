# Supabase project (Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable key (new format: sb_publishable_...). Legacy anon key also works.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Secret key (new format: sb_secret_...). Legacy service_role key also works.
# Server-only. NEVER expose this to the browser.
SUPABASE_SECRET_KEY=sb_secret_xxx

# Public URL of the deployed app, used for QR codes and magic-link redirects.
# Falls back to the request origin when unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
