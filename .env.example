# --- Database: Neon Postgres (https://neon.tech) ---
# Pooled connection string from your Neon project dashboard.
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# --- File storage: Vercel Blob (https://vercel.com/docs/storage/vercel-blob) ---
# Create a Blob store in your Vercel project, then pull the token with
# `vercel env pull` or copy it from the store settings.
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx

# --- Auth.js (host magic-link sign-in) ---
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=replace-me

# Magic-link email delivery (optional in dev).
# If EMAIL_SERVER is unset, sign-in links are printed to the server console
# so you can develop without any email provider.
# Example SMTP URL: smtp://user:pass@smtp.host.com:587
EMAIL_SERVER=
EMAIL_FROM=once more <onboarding@resend.dev>

# Public URL of the deployed app, used for QR codes.
# Falls back to the request origin when unset.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
